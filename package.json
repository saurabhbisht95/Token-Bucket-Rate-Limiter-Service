{
  "name": "token-bucket-rate-limiter-service",
  "version": "1.0.0",
  "description": "Standalone production-ready rate limiter API using token bucket and sliding window algorithms.",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "npm run build:frontend",
    "build:frontend": "vite build",
    "frontend:dev": "vite --host 0.0.0.0",
    "migrate": "node src/db/migrate.js",
    "load:token": "k6 run tests/load/token-bucket-500rps.js",
    "load:sliding": "k6 run tests/load/sliding-window-500rps.js",
    "admin:key:create": "node src/scripts/createAdminKey.js"
  },
  "keywords": [
    "rate-limiter",
    "token-bucket",
    "sliding-window",
    "redis",
    "postgres"
  ],
  "author": "Saurabh Bisht",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.18.3",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "pg": "^8.12.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "nodemon": "^3.1.7",
    "pino-pretty": "^13.1.3",
    "vite": "^6.0.7"
  }
}
